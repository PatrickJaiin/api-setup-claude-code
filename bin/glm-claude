#!/usr/bin/env bash
# glm-claude — run Claude Code against GLM on NVIDIA NIM through a local
# Anthropic<->OpenAI translation proxy (fuergaosi233/claude-code-proxy).
#
# Usage:
#   glm-claude [args...]      start proxy if needed, then exec `claude [args...]`
#   glm-claude start          start the background proxy
#   glm-claude stop           stop the background proxy
#   glm-claude restart        restart the background proxy
#   glm-claude status         report proxy state (exit 0 running, 1 not)
#   glm-claude logs           tail -f the proxy log
#   glm-claude doctor         smoke-test the whole chain
#   glm-claude help           show this help
set -euo pipefail

GLM_CLAUDE_HOME="${GLM_CLAUDE_HOME:-$HOME/.glm-claude}"
PROXY_DIR="$GLM_CLAUDE_HOME/claude-code-proxy"
VENV_DIR="$GLM_CLAUDE_HOME/venv"
PID_FILE="$GLM_CLAUDE_HOME/proxy.pid"
LOG_FILE="$GLM_CLAUDE_HOME/proxy.log"
KEY_FILE="$GLM_CLAUDE_HOME/nvidia.key"
CONFIG_FILE="$GLM_CLAUDE_HOME/config.env"
ENV_FILE="$PROXY_DIR/.env"

# --- defaults; override in ~/.glm-claude/config.env (see config.env.example) ---
GLM_MODEL="z-ai/glm-5.2"
OPENAI_BASE_URL="https://integrate.api.nvidia.com/v1"
PROXY_HOST="127.0.0.1"
PROXY_PORT="8082"
PROXY_LOG_LEVEL="WARNING"
MAX_TOKENS_LIMIT="16384"
REQUEST_TIMEOUT="300"
API_TIMEOUT_MS="600000"
BIG_MODEL=""
MIDDLE_MODEL=""
SMALL_MODEL=""

if [ -f "$CONFIG_FILE" ]; then
  # shellcheck source=/dev/null
  . "$CONFIG_FILE"
fi

BIG_MODEL="${BIG_MODEL:-$GLM_MODEL}"
MIDDLE_MODEL="${MIDDLE_MODEL:-$GLM_MODEL}"
SMALL_MODEL="${SMALL_MODEL:-$GLM_MODEL}"

# --- logging (stderr, so `glm-claude -p ...` keeps stdout clean) ---
if [ -t 2 ] && [ -z "${NO_COLOR:-}" ]; then
  C_BLUE=$'\033[34m' C_YELLOW=$'\033[33m' C_RED=$'\033[31m' C_GREEN=$'\033[32m' C_RESET=$'\033[0m'
else
  C_BLUE="" C_YELLOW="" C_RED="" C_GREEN="" C_RESET=""
fi
info() { printf '%s[glm-claude]%s %s\n' "$C_BLUE" "$C_RESET" "$*" >&2; }
warn() { printf '%s[glm-claude] warn:%s %s\n' "$C_YELLOW" "$C_RESET" "$*" >&2; }
err()  { printf '%s[glm-claude] error:%s %s\n' "$C_RED" "$C_RESET" "$*" >&2; }
ok()   { printf '%s[glm-claude]%s %s✓%s %s\n' "$C_BLUE" "$C_RESET" "$C_GREEN" "$C_RESET" "$*" >&2; }
fail() { printf '%s[glm-claude]%s %s✗%s %s\n' "$C_BLUE" "$C_RESET" "$C_RED" "$C_RESET" "$*" >&2; }

usage() {
  sed -n '2,14p' "$0" | sed 's/^# \{0,1\}//'
}

proxy_url() { printf 'http://%s:%s' "$PROXY_HOST" "$PROXY_PORT"; }

proxy_pid() {
  if [ -f "$PID_FILE" ]; then
    cat "$PID_FILE" 2>/dev/null || true
  fi
}

proxy_running() {
  local pid
  pid="$(proxy_pid)"
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

clear_stale_pid() {
  if [ -f "$PID_FILE" ] && ! proxy_running; then
    warn "removing stale PID file ($PID_FILE)"
    rm -f "$PID_FILE"
  fi
}

# The server is "up" if it answers HTTP at all: 404 on /health still proves
# the socket is being served, only 5xx / no-connection count as down.
http_up() {
  local code
  code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 2 "$(proxy_url)/health" 2>/dev/null || true)"
  [ -n "$code" ] && [ "$code" != "000" ] && [ "$code" -lt 500 ]
}

get_api_key() {
  if [ -n "${NVIDIA_API_KEY:-}" ]; then
    printf '%s' "$NVIDIA_API_KEY"
  elif [ -f "$KEY_FILE" ]; then
    cat "$KEY_FILE"
  else
    return 1
  fi
}

# Regenerate the proxy .env from config + key on every start, so edits to
# ~/.glm-claude/config.env take effect with a plain `glm-claude restart`.
write_proxy_env() {
  local key
  if ! key="$(get_api_key)"; then
    if [ -f "$ENV_FILE" ]; then
      warn "no NVIDIA API key in \$NVIDIA_API_KEY or $KEY_FILE; keeping existing proxy .env"
      return 0
    fi
    err "no NVIDIA API key found: export NVIDIA_API_KEY or re-run install.sh"
    return 1
  fi
  mkdir -p "$PROXY_DIR"
  (
    umask 077
    cat >"$ENV_FILE" <<EOF
OPENAI_API_KEY="$key"
OPENAI_BASE_URL="$OPENAI_BASE_URL"
BIG_MODEL="$BIG_MODEL"
MIDDLE_MODEL="$MIDDLE_MODEL"
SMALL_MODEL="$SMALL_MODEL"
HOST="$PROXY_HOST"
PORT="$PROXY_PORT"
LOG_LEVEL="$PROXY_LOG_LEVEL"
MAX_TOKENS_LIMIT="$MAX_TOKENS_LIMIT"
REQUEST_TIMEOUT="$REQUEST_TIMEOUT"
EOF
  )
  chmod 600 "$ENV_FILE"
}

wait_healthy() {
  local tries=0
  while [ "$tries" -lt 30 ]; do
    if http_up; then
      ok "proxy healthy on $(proxy_url) (pid $(proxy_pid))"
      return 0
    fi
    if ! proxy_running; then
      break
    fi
    sleep 0.5
    tries=$((tries + 1))
  done
  err "proxy failed health check after 15s; last 20 log lines:"
  tail -n 20 "$LOG_FILE" >&2 2>/dev/null || true
  if proxy_running; then
    kill "$(proxy_pid)" 2>/dev/null || true
  fi
  rm -f "$PID_FILE"
  return 1
}

cmd_start() {
  clear_stale_pid
  if proxy_running; then
    info "proxy already running (pid $(proxy_pid)) — nothing to do"
    return 0
  fi
  mkdir -p "$GLM_CLAUDE_HOME"
  write_proxy_env
  info "starting proxy on $(proxy_url) ..."
  if [ -n "${GLM_CLAUDE_PROXY_CMD:-}" ]; then
    # Test hook: run an arbitrary command as the proxy process.
    nohup bash -c "exec $GLM_CLAUDE_PROXY_CMD" >>"$LOG_FILE" 2>&1 &
    echo $! >"$PID_FILE"
  else
    if [ ! -x "$VENV_DIR/bin/python" ]; then
      err "python venv not found at $VENV_DIR — run install.sh first"
      return 1
    fi
    if [ ! -f "$PROXY_DIR/start_proxy.py" ]; then
      err "proxy not found at $PROXY_DIR — run install.sh first"
      return 1
    fi
    (
      cd "$PROXY_DIR"
      nohup "$VENV_DIR/bin/python" start_proxy.py >>"$LOG_FILE" 2>&1 &
      echo $! >"$PID_FILE"
    )
  fi
  wait_healthy
}

cmd_stop() {
  clear_stale_pid
  if ! proxy_running; then
    info "proxy is not running"
    return 0
  fi
  local pid waited=0
  pid="$(proxy_pid)"
  info "stopping proxy (pid $pid) ..."
  kill "$pid" 2>/dev/null || true
  while kill -0 "$pid" 2>/dev/null && [ "$waited" -lt 10 ]; do
    sleep 0.5
    waited=$((waited + 1))
  done
  if kill -0 "$pid" 2>/dev/null; then
    warn "proxy did not exit after 5s; sending SIGKILL"
    kill -9 "$pid" 2>/dev/null || true
  fi
  rm -f "$PID_FILE"
  ok "proxy stopped"
}

cmd_status() {
  clear_stale_pid
  if proxy_running; then
    if http_up; then
      ok "proxy running (pid $(proxy_pid)), healthy on $(proxy_url)"
    else
      warn "proxy running (pid $(proxy_pid)) but not answering HTTP on $(proxy_url)"
    fi
    return 0
  fi
  info "proxy is not running"
  return 1
}

cmd_logs() {
  if [ ! -f "$LOG_FILE" ]; then
    err "no log file yet at $LOG_FILE"
    return 1
  fi
  exec tail -f "$LOG_FILE"
}

cmd_doctor() {
  local problems=0 resp

  if command -v claude >/dev/null 2>&1; then
    ok "claude CLI found ($(command -v claude))"
  else
    fail "claude CLI not found — install with: npm install -g @anthropic-ai/claude-code"
    problems=1
  fi

  if get_api_key >/dev/null; then
    ok "NVIDIA API key available"
  else
    fail "no NVIDIA API key (\$NVIDIA_API_KEY or $KEY_FILE) — re-run install.sh"
    problems=1
  fi

  if proxy_running && http_up; then
    ok "proxy responding on $(proxy_url)"
  elif proxy_running; then
    fail "proxy process alive (pid $(proxy_pid)) but not answering HTTP on $(proxy_url)"
    problems=1
  else
    fail "proxy not running — start it with: glm-claude start"
    problems=1
  fi

  if [ "$problems" -eq 0 ]; then
    info "sending a test request through the proxy to the model (can take a minute) ..."
    resp="$(curl -sS --max-time "$REQUEST_TIMEOUT" -X POST "$(proxy_url)/v1/messages" \
      -H 'content-type: application/json' \
      -H 'x-api-key: proxy-local' \
      -H 'anthropic-version: 2023-06-01' \
      -d '{"model":"claude-sonnet-4-20250514","max_tokens":64,"messages":[{"role":"user","content":"Reply with the single word OK."}]}' \
      2>/dev/null || true)"
    if printf '%s' "$resp" | python3 -c '
import json, sys
d = json.load(sys.stdin)
assert d.get("type") == "message", "type != message"
assert d.get("role") == "assistant", "role != assistant"
assert isinstance(d.get("content"), list) and d["content"], "empty content"
' 2>/dev/null; then
      ok "end-to-end /v1/messages round trip returned a well-formed message"
    else
      fail "/v1/messages round trip failed — check 'glm-claude logs' for upstream errors"
      if [ -n "$resp" ]; then
        printf '%s\n' "$resp" | head -c 500 >&2
        printf '\n' >&2
      fi
      problems=1
    fi
  else
    warn "skipping end-to-end request until the checks above pass"
  fi

  if [ "$problems" -eq 0 ]; then
    ok "all checks passed"
  else
    err "doctor found problems"
  fi
  return "$problems"
}

cmd_run() {
  cmd_start
  exec env \
    ANTHROPIC_BASE_URL="$(proxy_url)" \
    ANTHROPIC_API_KEY="proxy-local" \
    API_TIMEOUT_MS="$API_TIMEOUT_MS" \
    claude "$@"
}

case "${1:-}" in
  start)   shift; cmd_start "$@" ;;
  stop)    shift; cmd_stop "$@" ;;
  restart) shift; cmd_stop; cmd_start ;;
  status)  shift; cmd_status "$@" ;;
  logs)    shift; cmd_logs "$@" ;;
  doctor)  shift; cmd_doctor "$@" ;;
  help|-h|--help) usage ;;
  *)       cmd_run "$@" ;;
esac
