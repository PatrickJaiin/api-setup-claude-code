# glm-claude configuration
#
# Copy this file to ~/.glm-claude/config.env to override defaults:
#
#   cp config.env.example ~/.glm-claude/config.env
#
# The launcher sources ~/.glm-claude/config.env (plain bash syntax) on every
# invocation and regenerates the proxy .env on every `glm-claude start`, so
# changes take effect after `glm-claude restart`. All values below show the
# built-in defaults.

# Model served by NVIDIA NIM, in NIM's own naming scheme.
# Applied to all three Claude Code tiers (opus/sonnet/haiku) unless the
# per-tier overrides below are set. Note: the model string is mapped inside
# the proxy on purpose — Claude Code itself cannot handle a "/" in
# ANTHROPIC_MODEL, so never export that variable yourself.
#GLM_MODEL="z-ai/glm-5.2"

# Per-tier overrides (default: $GLM_MODEL for all three).
# BIG = opus-class, MIDDLE = sonnet-class, SMALL = haiku-class requests.
#BIG_MODEL=""
#MIDDLE_MODEL=""
#SMALL_MODEL=""

# OpenAI-compatible upstream the proxy forwards to.
#OPENAI_BASE_URL="https://integrate.api.nvidia.com/v1"

# Address the local translation proxy listens on.
#PROXY_HOST="127.0.0.1"
#PROXY_PORT="8082"

# Proxy log verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL.
#PROXY_LOG_LEVEL="WARNING"

# Max tokens the proxy will request per completion. The proxy's own default
# (4096) truncates long agentic turns, so glm-claude raises it.
#MAX_TOKENS_LIMIT="16384"

# Seconds the proxy waits on the upstream before giving up.
#REQUEST_TIMEOUT="300"

# Milliseconds Claude Code waits on the proxy (exported as API_TIMEOUT_MS).
#API_TIMEOUT_MS="600000"
