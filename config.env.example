# glm-claude configuration
#
# Copy this file to ~/.glm-claude/config.env to override defaults:
#
#   cp config.env.example ~/.glm-claude/config.env
#
# The launcher sources ~/.glm-claude/config.env (plain bash syntax) on every
# invocation and regenerates the LiteLLM config (~/.glm-claude/litellm.yaml)
# on every `glm-claude start`, so changes take effect after
# `glm-claude restart`. All values below show the built-in defaults.

# Model served by the provider, in the provider's own naming scheme.
# Applied to all three Claude Code tiers (opus/sonnet/haiku) unless the
# per-tier overrides below are set. Note: the model name is mapped inside
# the LiteLLM router on purpose — Claude Code itself cannot handle a "/" in
# ANTHROPIC_MODEL, so never export that variable yourself.
#GLM_MODEL="z-ai/glm-5.2"

# Per-tier overrides (default: $GLM_MODEL for all three).
# BIG = opus-class, MIDDLE = sonnet-class, SMALL = haiku-class requests.
# Anything that matches no tier (unknown model names) is routed to BIG.
#BIG_MODEL=""
#MIDDLE_MODEL=""
#SMALL_MODEL=""

# OpenAI-compatible upstream the router forwards to.
#OPENAI_BASE_URL="https://integrate.api.nvidia.com/v1"

# LiteLLM provider prefix used in front of the model name. "nvidia_nim" fits
# the default base URL; for any other OpenAI-compatible server (vLLM,
# together, groq, a self-hosted gateway, ...) use "hosted_vllm" or the
# provider's own LiteLLM prefix (https://docs.litellm.ai/docs/providers).
# Avoid plain "openai" for servers that lack the /v1/responses endpoint.
#LITELLM_PROVIDER="nvidia_nim"

# Address the local LiteLLM router listens on.
#PROXY_HOST="127.0.0.1"
#PROXY_PORT="8082"

# Router log verbosity (LITELLM_LOG): DEBUG, INFO, WARNING, ERROR.
#PROXY_LOG_LEVEL="WARNING"

# Seconds the router waits on the upstream before giving up.
#REQUEST_TIMEOUT="300"

# Milliseconds Claude Code waits on the router (exported as API_TIMEOUT_MS).
#API_TIMEOUT_MS="600000"
